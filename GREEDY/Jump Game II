class Solution {
public:
    int jump(vector<int>& nums) {
        int n=nums.size();
        int currEnd=0;
        int maxReach=0;
        int jump=0;

        for(int i=0; i<n-1; i++){
            maxReach=max(maxReach, i + nums[i]);
            if(currEnd==i){
                currEnd=maxReach;
                jump++;
            }
            if(currEnd>=n-1)break;
        }
        return jump;
    }
};